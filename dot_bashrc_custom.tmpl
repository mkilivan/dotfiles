# Personal bash additions — managed by chezmoi, sourced from ~/.bashrc

export PATH="$PATH:$HOME/.local/bin"

# fzf binary path (git install on Linux)
[ -d "$HOME/.fzf/bin" ] && export PATH="$HOME/.fzf/bin:$PATH"

# eza — modern ls replacement
if command -v eza &>/dev/null; then
    alias ls='eza --color=auto'
    alias ll='eza -la --git'
    alias l='eza -la'
fi

{{ if eq .chezmoi.os "darwin" -}}
# Homebrew (Apple Silicon)
[ -f /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
# Homebrew (Intel)
[ -f /usr/local/bin/brew ] && eval "$(/usr/local/bin/brew shellenv)"
{{ end -}}

# Starship prompt
command -v starship &>/dev/null && eval "$(starship init bash)"

# fzf - keybindings and completion for Bash
if command -v fzf &>/dev/null; then
    eval "$(fzf --bash)" 2>/dev/null || { [ -f "$HOME/.fzf.bash" ] && source "$HOME/.fzf.bash"; }
elif [ -f "$HOME/.fzf.bash" ]; then
    source "$HOME/.fzf.bash"
fi

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
